# Database Configuration
POSTGRES_USER=documind
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=documind
DATABASE_URL=postgresql+asyncpg://documind:your_password_here@postgres:5432/documind

# Redis Configuration
REDIS_URL=redis://redis:6379

# API Configuration
API_PORT=8000

# File Upload Settings
MAX_FILE_SIZE_MB=50

# Model Configuration (for later)
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=llama3.2:3b

# Optional: OpenAI API (if using instead of Ollama)
# OPENAI_API_KEY=sk-...
GROQ_API_KEY=your_key_here
